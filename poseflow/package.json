{
  "name": "poseflow-editor",
  "version": "0.1.0",
  "description": "PoseFlow Editor - 3D Pose Editor for ControlNet",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npx vite",
    "build": "tsc && npx vite build",
    "preview": "npx vite preview",
    "electron:dev": "concurrently \"npx vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npx vite build && electron-builder",
    "backend": "cd backend && python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts"
  },
  "keywords": ["pose", "3d", "controlnet", "editor"],
  "author": "PoseFlow Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^2.1.9",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.163.0"
  }
}
